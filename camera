// to use this code, make sure you call "initCamera()" in your "init" function
// add "updateCamera()" in your "update" function.

// you will need to subtract the camera from everything you are drawing in the
// game, e.g. "player.x - camera.x, player.y - camera.y"

// the camera is set to follow an object called "player", but you can
// change the code to work some other way


initCamera = function()
  camera = object
    x = player.x         // actual position of camera (& starting position)
    y = player.y 
    x_drag = 25     // the amount of movement the player has to make in each
    y_drag = 40     // before the camera is forced to follow
    smoothing = 0.9 // how much the camera slows/smoothes its movement (range 0-1)
  end
  camera.target_x = camera.x     // target position being smoothly moved towards
  camera.target_y = camera.y
end

updateCamera = function()
  // clamp camera target to player
  camera.target_x = help.clamp(camera.target_x, player.x - camera.x_drag, player.x + camera.x_drag)
  camera.target_y = help.clamp(camera.target_y, player.y - camera.y_drag, player.y + camera.y_drag)
  
  // override if necessary to clamp camera target to level limits
  local x_limit = world.draw_width / 2 - screen.width / 2
  local y_limit = world.draw_height / 2 - screen.height / 2
  camera.target_x = help.clamp(camera.target_x, -x_limit, x_limit)
  camera.target_y = help.clamp(camera.target_y, -y_limit, y_limit)
  
  // move camera towards target smoothly
  camera.x += (camera.target_x - camera.x) * (1 - camera.smoothing)
  camera.y += (camera.target_y - camera.y) * (1 - camera.smoothing)
  
  // avoid extremely slow camera smoothing at the end of a move
  // as it creates weird pixel effects
  if abs(camera.target_x - camera.x) < 0.2 then
    camera.x = camera.target_x
  end
  if abs(camera.target_y - camera.y) < 0.2 then
    camera.y = camera.target_y
  end
  
end
